{
  "name": "vcard-qr",
  "version": "1.0.0",
  "description": "vCard QR code generator — web app, CLI, and MCP server",
  "type": "module",
  "bin": {
    "vcard-qr": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "vite",
